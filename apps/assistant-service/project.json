{
  "name": "assistant-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/assistant-service",
  "projectType": "application",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/assistant-service",
        "command": "..\\..\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --host 0.0.0.0 --port 8002 --reload"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/assistant-service",
        "command": "..\\..\\.venv\\Scripts\\python.exe -m pytest"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/assistant-service",
        "command": "..\\..\\.venv\\Scripts\\python.exe -m ruff check ."
      }
    }
  },
  "tags": ["scope:backend", "type:assistant"]
}