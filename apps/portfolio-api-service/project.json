{
  "name": "portfolio-api-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/portfolio-api-service",
  "projectType": "application",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/portfolio-api-service",
        "command": "..\\..\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --host 0.0.0.0 --port 8011 --reload"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/portfolio-api-service",
        "command": "..\\..\\.venv\\Scripts\\python.exe -m pytest"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/portfolio-api-service",
        "command": "..\\..\\.venv\\Scripts\\python.exe -m ruff check ."
      }
    },
    "db-migrate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": ".\\.venv\\Scripts\\python.exe -m infra.postgres.migrations.cli upgrade head"
      }
    },
    "db-migration-check": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": ".\\.venv\\Scripts\\python.exe -m infra.postgres.migrations.cli check"
      }
    }
  },
  "tags": [
    "scope:backend",
    "type:api"
  ]
}