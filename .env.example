# Global
APP_ENV=development
POSTGRES_DB=portfolio_platform
POSTGRES_USER=portfolio_user
POSTGRES_PASSWORD=portfolio_pass
POSTGRES_PORT=5432
REDIS_PORT=6380

# Portfolio API
PORTFOLIO_API_PORT=8011
PORTFOLIO_API_HOST=0.0.0.0
PORTFOLIO_API_DB_URL=postgresql+psycopg://portfolio_user:portfolio_pass@postgres:5432/portfolio_platform
PORTFOLIO_API_SECRET_KEY=change-me
PORTFOLIO_API_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
PORTFOLIO_API_ADMIN_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Assistant API
ASSISTANT_API_PORT=8012
ASSISTANT_API_HOST=0.0.0.0
ASSISTANT_API_DB_URL=postgresql+psycopg://portfolio_user:portfolio_pass@postgres:5432/portfolio_platform
ASSISTANT_API_REDIS_URL=redis://redis:6379/0
ASSISTANT_API_SECRET_KEY=change-me-too
ASSISTANT_API_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
ASSISTANT_PROVIDER_BACKEND=ollama
ASSISTANT_PROVIDER_MODEL=qwen2.5:3b
ASSISTANT_PROVIDER_BASE_URL=http://ollama:11434
ASSISTANT_PROVIDER_API_KEY=
ASSISTANT_RETRIEVAL_CHUNK_LIMIT=5
ASSISTANT_RETRIEVAL_CANDIDATE_LIMIT=18
OLLAMA_PORT=11534

# Frontend
WEB_PORT=4200

DB_BOOTSTRAP_SEED_MODE=if-empty
DB_BOOTSTRAP_RECREATE_ON_DRIFT=false
# seed modes: if-empty (default), always, never
# deprecated: migrations are authoritative; leave this false
DB_BOOTSTRAP_MAX_RETRIES=30
DB_BOOTSTRAP_RETRY_DELAY_SECONDS=2

# MinIO public media
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001
MINIO_PUBLIC_BUCKET=portfolio
MEDIA_PUBLIC_BASE_URL=http://localhost:19000
MEDIA_STORAGE_ENDPOINT=minio:9000
MEDIA_STORAGE_ACCESS_KEY=minioadmin
MEDIA_STORAGE_SECRET_KEY=minioadmin
MEDIA_STORAGE_SECURE=false
MEDIA_PUBLIC_BUCKET=portfolio
MEDIA_MAX_UPLOAD_BYTES=52428800 
MINIO_HEAL_STALE_OPENID_CONFIG=true

# Seeded admin CMS account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin
ADMIN_DISPLAY_NAME=Portfolio Admin
GITHUB_STATS_USERNAME=Alex-v-p
GITHUB_API_TOKEN=
GITHUB_STATS_LOOKBACK_DAYS=365

ASSISTANT_RETRIEVAL_EMBEDDING_BACKEND=ollama
ASSISTANT_RETRIEVAL_EMBEDDING_MODEL=nomic-embed-text
ASSISTANT_RETRIEVAL_EMBEDDING_BASE_URL=http://ollama:11434
ASSISTANT_RETRIEVAL_EMBEDDING_API_KEY=
ASSISTANT_RETRIEVAL_EMBEDDING_TIMEOUT_SECONDS=20
KNOWLEDGE_EMBEDDING_BACKEND=ollama
KNOWLEDGE_EMBEDDING_MODEL=nomic-embed-text
KNOWLEDGE_EMBEDDING_BASE_URL=http://ollama:11434
KNOWLEDGE_EMBEDDING_API_KEY=
KNOWLEDGE_EMBEDDING_TIMEOUT_SECONDS=20


PORTFOLIO_API_CONTACT_RATE_LIMIT_MAX_REQUESTS=5
PORTFOLIO_API_CONTACT_RATE_LIMIT_WINDOW_SECONDS=600
PORTFOLIO_API_CONTACT_MAX_REQUEST_BYTES=16384
PORTFOLIO_API_EVENTS_RATE_LIMIT_MAX_REQUESTS=60
PORTFOLIO_API_EVENTS_RATE_LIMIT_WINDOW_SECONDS=60
PORTFOLIO_API_EVENTS_MAX_REQUEST_BYTES=65536
PORTFOLIO_API_EVENTS_METADATA_MAX_ENTRIES=25
PORTFOLIO_API_EVENTS_METADATA_MAX_DEPTH=3
PORTFOLIO_API_EVENTS_METADATA_MAX_LIST_ITEMS=20
PORTFOLIO_API_EVENTS_METADATA_MAX_STRING_LENGTH=500
PORTFOLIO_API_MEDIA_UPLOAD_RATE_LIMIT_MAX_REQUESTS=20
PORTFOLIO_API_MEDIA_UPLOAD_RATE_LIMIT_WINDOW_SECONDS=300
ASSISTANT_CHAT_RATE_LIMIT_MAX_REQUESTS=12
ASSISTANT_CHAT_RATE_LIMIT_WINDOW_SECONDS=60
ASSISTANT_CHAT_MAX_REQUEST_BYTES=16384
ASSISTANT_PROVIDER_REQUEST_TIMEOUT_SECONDS=25
ASSISTANT_PROVIDER_MAX_RETRIES=1
ASSISTANT_PROVIDER_DAILY_GENERATION_CAP=1000

SITE_EVENTS_RETENTION_DAYS=90
ASSISTANT_ACTIVITY_RETENTION_DAYS=90
MAINTENANCE_CHECK_INTERVAL_SECONDS=60
MAINTENANCE_LOCK_TTL_SECONDS=900
MAINTENANCE_STATE_TTL_SECONDS=2592000
RETENTION_CLEANUP_INTERVAL_SECONDS=86400
RETENTION_CLEANUP_RETRY_INTERVAL_SECONDS=3600
GITHUB_AUTO_REFRESH_ENABLED=true
GITHUB_AUTO_REFRESH_INTERVAL_SECONDS=86400
GITHUB_AUTO_REFRESH_RETRY_INTERVAL_SECONDS=3600
