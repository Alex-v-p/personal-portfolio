# Global
POSTGRES_DB=portfolio_platform
POSTGRES_USER=portfolio_user
POSTGRES_PASSWORD=portfolio_pass
POSTGRES_PORT=5432
REDIS_PORT=6380

# Portfolio API
PORTFOLIO_API_PORT=8011
PORTFOLIO_API_HOST=0.0.0.0
PORTFOLIO_API_DB_URL=postgresql+psycopg://portfolio_user:portfolio_pass@postgres:5432/portfolio_platform
PORTFOLIO_API_SECRET_KEY=change-me
PORTFOLIO_API_ADMIN_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Assistant API
ASSISTANT_API_PORT=8012
ASSISTANT_API_HOST=0.0.0.0
ASSISTANT_API_DB_URL=postgresql+psycopg://portfolio_user:portfolio_pass@postgres:5432/portfolio_platform
ASSISTANT_API_REDIS_URL=redis://redis:6380/0
ASSISTANT_API_SECRET_KEY=change-me-too
ASSISTANT_API_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
ASSISTANT_PROVIDER_BACKEND=ollama
ASSISTANT_PROVIDER_MODEL=qwen2.5:3b
ASSISTANT_PROVIDER_BASE_URL=http://ollama:11434
ASSISTANT_PROVIDER_API_KEY=
ASSISTANT_RETRIEVAL_CHUNK_LIMIT=5
ASSISTANT_RETRIEVAL_CANDIDATE_LIMIT=18
OLLAMA_PORT=11434

# Frontend
WEB_PORT=4200
PORTFOLIO_API_BASE_URL=http://localhost:8011
ASSISTANT_API_BASE_URL=http://localhost:8012

DB_BOOTSTRAP_AUTO_SEED=true
DB_BOOTSTRAP_RECREATE_ON_DRIFT=true
DB_BOOTSTRAP_MAX_RETRIES=30
DB_BOOTSTRAP_RETRY_DELAY_SECONDS=2

# MinIO public media
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_PUBLIC_BUCKET=portfolio
MEDIA_PUBLIC_BASE_URL=http://localhost:9000
MEDIA_STORAGE_ENDPOINT=minio:9000
MEDIA_STORAGE_ACCESS_KEY=minioadmin
MEDIA_STORAGE_SECRET_KEY=minioadmin
MEDIA_STORAGE_SECURE=false
MEDIA_PUBLIC_BUCKET=portfolio
MEDIA_MAX_UPLOAD_BYTES=52428800 
MINIO_HEAL_STALE_OPENID_CONFIG=true

# Seeded admin CMS account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin
ADMIN_DISPLAY_NAME=Portfolio Admin
GITHUB_STATS_USERNAME=Alex-v-p
GITHUB_API_TOKEN=
GITHUB_STATS_LOOKBACK_DAYS=365

ASSISTANT_RETRIEVAL_EMBEDDING_BACKEND=ollama
ASSISTANT_RETRIEVAL_EMBEDDING_MODEL=nomic-embed-text
ASSISTANT_RETRIEVAL_EMBEDDING_BASE_URL=http://ollama:11434
ASSISTANT_RETRIEVAL_EMBEDDING_API_KEY=
ASSISTANT_RETRIEVAL_EMBEDDING_TIMEOUT_SECONDS=20
KNOWLEDGE_EMBEDDING_BACKEND=ollama
KNOWLEDGE_EMBEDDING_MODEL=nomic-embed-text
KNOWLEDGE_EMBEDDING_BASE_URL=http://ollama:11434
KNOWLEDGE_EMBEDDING_API_KEY=
KNOWLEDGE_EMBEDDING_TIMEOUT_SECONDS=20
